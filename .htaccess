# ╔══════════════════════════════════════════════════════════════════════╗
# ║  .HTACCESS — SIGED v5.0 DUAL-ENTORNO                                ║
# ║  Funciona en XAMPP (subcarpeta) Y Render (raíz) sin modificación    ║
# ╠══════════════════════════════════════════════════════════════════════╣
# ║  XAMPP:  el proyecto vive en htdocs/ISPEB_Expedientes/               ║
# ║          RewriteBase se resuelve automáticamente por PHP (config.php)║
# ║  Render: el proyecto vive en /var/www/html/ (raíz del contenedor)    ║
# ║          RewriteBase / es correcto                                   ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ── 1. DESHABILITAR LISTADO DE DIRECTORIOS ────────────────────────────────────
Options -Indexes -MultiViews

# ── 2. PROTEGER ESTE MISMO ARCHIVO ───────────────────────────────────────────
<Files ".htaccess">
    Order Allow,Deny
    Deny from all
</Files>

# ── 3. REGLAS DE REESCRITURA ──────────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # RewriteBase /
    # NOTA: No se necesita cambiar esta directiva entre entornos.
    # config.php calcula APP_URL con la subcarpeta correcta (/ISPEB_Expedientes
    # en XAMPP, vacío en Render) usando DOCUMENT_ROOT + dirname(__DIR__).
    # Todos los href, src y header("Location: ".APP_URL."/...") ya incluyen
    # la subcarpeta en la URL, por lo que Apache recibe la ruta completa.
    RewriteBase /

    # ── Paso libre: assets públicos ──────────────────────────────────────────
    RewriteRule ^publico(/.*)?$       - [L]
    RewriteRule ^subidas(/.*)?$       - [L]
    RewriteRule ^config/logout\.php$  - [L]

    # ── Bloquear acceso HTTP directo a código fuente ─────────────────────────
    RewriteRule ^(config|database|modelos|lib)(/.*)?$ - [F,L]
</IfModule>

# ── 4. BLOQUEAR ARCHIVOS OCULTOS Y SENSIBLES ─────────────────────────────────
<FilesMatch "(^\.|\.(git|env|sql|log|md|json|lock|pem|key|bak|swp))$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# ── 5. PROTEGER ARCHIVOS SENSIBLES POR EXTENSIÓN ─────────────────────────────
<FilesMatch "\.(sql|log|bak|env|ini|sh|pem|key)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# ── 6. CABECERAS DE SEGURIDAD HTTP ───────────────────────────────────────────
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header unset X-Powered-By
</IfModule>

# ── 7. UTF-8 ──────────────────────────────────────────────────────────────────
AddDefaultCharset UTF-8
