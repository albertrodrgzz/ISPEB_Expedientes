# ╔═══════════════════════════════════════════════════════════════════╗
# ║  .HTACCESS MAESTRO — SIGED v3.5                                    ║
# ║  Compatible con .htaccess (sin DirectoryMatch ni LimitRequestBody) ║
# ╚═══════════════════════════════════════════════════════════════════╝

# ── 1. DESHABILITAR LISTADO DE DIRECTORIOS ───────────────────────────────────
Options -Indexes -MultiViews

# ── 2. PROTEGER ESTE MISMO ARCHIVO ──────────────────────────────────────────
<Files ".htaccess">
    Order Allow,Deny
    Deny from all
</Files>

# ── 3. BLOQUEAR ACCESO A DIRECTORIOS SENSIBLES (via RewriteRule) ────────────
# Excepciones públicas PRIMERO (deben ir ANTES de las reglas de bloqueo)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /APP3/

    # EXCEPCIÓN: config/logout.php debe ser accesible (cierre de sesión)
    RewriteRule ^config/logout\.php$ - [L]

    # Bloquear acceso HTTP directo al resto de config/, database/, modelos/, lib/
    RewriteRule ^(config|database|modelos|lib)(/.*)?$ - [F,L]
</IfModule>

# ── 4. BLOQUEAR ARCHIVOS OCULTOS Y SENSIBLES ────────────────────────────────
<FilesMatch "(^\.|\.git|\.env|\.sql|\.log|\.md|\.json|\.lock|\.pem|\.key|\.bak|\.swp)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# ── 5. PROTEGER ARCHIVOS SENSIBLES POR EXTENSIÓN ────────────────────────────
<FilesMatch "\.(sql|log|bak|env|ini|sh|pem|key)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# ── 6. CABECERAS DE SEGURIDAD HTTP ──────────────────────────────────────────
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header unset X-Powered-By
</IfModule>

# ── 7. FORZAR UTF-8 ──────────────────────────────────────────────────────────
AddDefaultCharset UTF-8
